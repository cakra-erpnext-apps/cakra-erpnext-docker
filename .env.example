COMPOSE_PROJECT_NAME=cakra_erpnext

# --- Site & credentials -------------------------------------------------
# For local dev:     SITE_NAME=erp.localhost, weak passwords OK
# For production:    SITE_NAME=<your-domain>, use strong random passwords
#                    (these are enforced by docker-compose.prod.yml; missing = boot failure)
#
# IMPORTANT: SITE_NAME must match the Host header hardcoded in the backend/nginx
# healthchecks in docker-compose.prod.yml (currently "app.oakdepo.com"). If you
# change SITE_NAME, also update both healthcheck lines or the containers will
# never become healthy.
SITE_NAME=erp.localhost
ADMIN_PASSWORD=admin
MYSQL_ROOT_PASSWORD=123

# --- Apps ---------------------------------------------------------------
INSTALL_APPS=erpnext,hrms,erpnext_custom,container_depot,crm,helpdesk,raven,gameplan,telephony
BUILD_APPS=frappe,erpnext,hrms,crm,helpdesk,raven,gameplan
SKIP_BUILD_APPS=erpnext_custom,container_depot

# --- Source repos / branches -------------------------------------------
FRAPPE_REPO=https://github.com/cakra-erpnext-apps/frappe
FRAPPE_BRANCH=version-16

# --- Dev-only ----------------------------------------------------------
# Only read by docker-compose.dev.yml. Defaults to 1 in dev, 0 in prod.
# Set to 0 if you want dev to behave like prod (cached assets_json etc.);
# leaving it at 1 prevents the desk-bundle 404 bug after migrate/test.
DEVELOPER_MODE=1

# --- Backup ------------------------------------------------------------
# Days to keep local backup files in ./backups/ before pruning.
BACKUP_RETENTION_DAYS=14