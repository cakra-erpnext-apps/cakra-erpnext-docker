COMPOSE_PROJECT_NAME=cakra_erpnext

# --- Site & credentials -------------------------------------------------
# For local dev:     SITE_NAME=erp.localhost, weak passwords OK
# For production:    SITE_NAME=erp.yourdomain.com, use strong random passwords
#                    (these are enforced by docker-compose.prod.yml; missing = boot failure)
SITE_NAME=erp.localhost
ADMIN_PASSWORD=admin
MYSQL_ROOT_PASSWORD=123

# --- Apps ---------------------------------------------------------------
INSTALL_APPS=erpnext,hrms,erpnext_custom,container_depot,crm,helpdesk,raven,gameplan,telephony
BUILD_APPS=frappe,erpnext,hrms,crm,helpdesk,raven,gameplan
SKIP_BUILD_APPS=erpnext_custom,container_depot

# --- Source repos / branches -------------------------------------------
FRAPPE_REPO=https://github.com/cakra-erpnext-apps/frappe
FRAPPE_BRANCH=version-16

# --- Backup ------------------------------------------------------------
# Days to keep local backup files in ./backups/ before pruning.
BACKUP_RETENTION_DAYS=14